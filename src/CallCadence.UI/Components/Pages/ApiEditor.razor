        _selectedLog = _selectedLog?.Id == args.Item.Id ? null : args.Item;
        _selectedLogJson = _selectedLog is null
            ? string.Empty
            : JsonSerializer.Serialize(_selectedLog, DefaultJsonSerializerOptions);
        _showSelectedLogJson = false;
        ClearCopyStatus();
    }

    private string GetLogRowClass(ApiCallLogDto item, int rowIndex)
    {
        _ = rowIndex;
        return _selectedLog?.Id == item.Id ? "call-log-row-selected" : string.Empty;
    }

    private async Task CopyDetailAsync(string fieldName, string? value)
    {
        try
        {
            using var cancellationTokenSource = new CancellationTokenSource(TimeSpan.FromSeconds(ClipboardOperationTimeoutSeconds));
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", cancellationTokenSource.Token, value ?? string.Empty);
            ShowCopySuccess(fieldName);
        }
        catch (OperationCanceledException ex)
        {
            Logger.LogWarning(ex, "Timed out copying API call log field {FieldName}", fieldName);
            ShowCopyError($"Timed out copying {fieldName}.");
        }
        catch (JSDisconnectedException ex)
        {
            Logger.LogWarning(ex, "JavaScript disconnected while copying API call log field {FieldName}", fieldName);
            ShowCopyError($"Unable to copy {fieldName}.");
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogWarning(ex, "Clipboard interop was unavailable for API call log field {FieldName}", fieldName);
            ShowCopyError($"Unable to copy {fieldName}.");
        }
        catch (JSException ex)
        {
            Logger.LogWarning(ex, "Unable to copy API call log field {FieldName}", fieldName);
            ShowCopyError($"Unable to copy {fieldName}.");
        }
    }

    private void AddSchedule()
    {
        _schedules.Add(new ScheduleEditorModel());
        UpdateSchedulePreview(_schedules[^1]);
    }

    private void RemoveSchedule(int index)
    {
        var schedule = _schedules[index];
        if (schedule.ScheduleId.HasValue)
        {
            _removedScheduleIds.Add(schedule.ScheduleId.Value);
        }

        _schedules.RemoveAt(index);
    }

    private void OnScheduleEnabledChanged(ScheduleEditorModel schedule, bool value)
    {
        schedule.IsEnabled = value;
        UpdateSchedulePreview(schedule);
    }

    private void OnScheduleCronExpressionChanged(ScheduleEditorModel schedule, string value)
    {
        schedule.CronExpression = value;
        UpdateSchedulePreview(schedule);
    }

    private void UpdateAllSchedulePreviews()
    {
        foreach (var schedule in _schedules)
        {
            UpdateSchedulePreview(schedule);
        }
    }

    private void UpdateSchedulePreview(ScheduleEditorModel schedule)
    {
        schedule.NextOccurrences.Clear();
        schedule.PreviewError = null;

        if (!TryValidateCron(schedule.CronExpression, out var error))
        {
            schedule.PreviewError = error;
            return;
        }

        var expression = CronExpression.Parse(schedule.CronExpression.Trim(), CronFormat.Standard);
        var from = DateTime.UtcNow;

        for (var i = 0; i < 3; i++)
        {
            var next = expression.GetNextOccurrence(from, TimeZoneInfo.Utc);
            if (!next.HasValue)
            {
                break;
            }

            schedule.NextOccurrences.Add(next.Value.ToString("yyyy-MM-dd HH:mm:ss 'UTC'"));
            from = next.Value.AddSeconds(1);
        }
    }

    private void AddHeader() => _model.Headers.Add(new NamedValue());

    private void RemoveHeader(int index) => _model.Headers.RemoveAt(index);

    private void AddParameter() => _model.Parameters.Add(new NamedValue());

    private void RemoveParameter(int index) => _model.Parameters.RemoveAt(index);

    private static bool TryValidateCron(string? cronExpression, out string? error)
    {
        if (string.IsNullOrWhiteSpace(cronExpression))
        {
            error = "CRON expression is required.";
            return false;
        }

        try
        {
            CronExpression.Parse(cronExpression.Trim(), CronFormat.Standard);
            error = null;
            return true;
        }
        catch (Exception)
        {
            error = "Invalid CRON expression. Use standard 5-part format.";
            return false;
        }
    }

    private static string FormatFlag(bool value) => value ? "Yes" : "No";

    private static string FormatLogExecutedAt(DateTime timestamp) =>
        timestamp.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private static string FormatDetailValue(string? value, string emptyValue = "—") =>
        string.IsNullOrWhiteSpace(value) ? emptyValue : value;

    private static string FormatNamedValues(IEnumerable<NamedValue> values)
    {
        var lines = values
            .Select(FormatNamedValue)
            .Where(formattedValue => !string.IsNullOrWhiteSpace(formattedValue))
            .ToList();

        return lines.Count == 0 ? string.Empty : string.Join(Environment.NewLine, lines);
    }

    private static string FormatNamedValue(NamedValue value)
    {
        var hasName = !string.IsNullOrWhiteSpace(value.Name);
        var hasValue = !string.IsNullOrWhiteSpace(value.Value);

        return (hasName, hasValue) switch
        {
            (true, true) => $"{value.Name}: {value.Value}",
            (true, false) => value.Name!,
            (false, true) => value.Value!,
            _ => string.Empty
        };
    }

    private static string GetRequestUriValue(ApiCallLogDto log) => log.RequestUri ?? string.Empty;

    private static string GetHttpMethodValue(ApiCallLogDto log) =>
        string.IsNullOrWhiteSpace(log.HttpMethod) ? UnknownHttpMethod : log.HttpMethod;

    private static string GetRequestHeadersValue(ApiCallLogDto log) => FormatNamedValues(log.RequestHeaders);

    private static string GetRequestParametersValue(ApiCallLogDto log) => FormatNamedValues(log.RequestParameters);

    private static string GetRequestBodyValue(ApiCallLogDto log) => log.RequestBody ?? string.Empty;

    private static string GetResponseCodeValue(ApiCallLogDto log) => log.ResponseCode.ToString();

    private static string GetResponseBodyValue(ApiCallLogDto log) => log.ResponseBody ?? string.Empty;

    private static string GetExecutedAtValue(ApiCallLogDto log) => FormatLogExecutedAt(log.ExecutedAt);

    private static string GetDurationMsValue(ApiCallLogDto log) => log.DurationMs.ToString();

    private static string GetSuccessValue(ApiCallLogDto log) => FormatFlag(log.Success);

    private static string GetErrorMessageValue(ApiCallLogDto log) => log.ErrorMessage ?? string.Empty;

    private static bool HasNonEmptyValue(string? value) => !string.IsNullOrWhiteSpace(value);

    private void ShowCopySuccess(string fieldName)
    {
        _lastCopiedField = fieldName;
        _copyErrorMessage = null;
        StartCopyStatusClear();
    }

    private void ShowCopyError(string message)
    {
        _lastCopiedField = null;
        _copyErrorMessage = message;
        StartCopyStatusClear();
    }

    private void ClearCopyStatus()
    {
        _copyStatusMessageVersion++;
        _lastCopiedField = null;
        _copyErrorMessage = null;
    }

    private void StartCopyStatusClear()
    {
        _copyStatusMessageVersion++;
        var statusVersion = _copyStatusMessageVersion;
        // Intentional fire-and-forget; DismissCopyStatusAsync handles its own exceptions and only clears the latest status message.
        _ = DismissCopyStatusAsync(statusVersion);
    }

    private async Task DismissCopyStatusAsync(long statusVersion)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(CopyStatusDisplayDurationSeconds));
            if (statusVersion != _copyStatusMessageVersion)
            {
                return;
            }

            _lastCopiedField = null;
            _copyErrorMessage = null;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Unable to clear API call log copy status message");
        }
    }

