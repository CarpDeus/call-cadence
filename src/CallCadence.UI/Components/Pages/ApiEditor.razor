    }

    private async Task<TableData<ApiCallLogDto>> LoadLogsAsync(TableState state, CancellationToken cancellationToken)
    {
        if (!_isEditMode || !ApiCallId.HasValue || !Session.IsAuthenticated)
        {
            return new TableData<ApiCallLogDto> { Items = [], TotalItems = 0 };
        }

        try
        {
            var response = await ApiClient.GetApiCallLogsPagedAsync(ApiCallId.Value, new ApiCallLogListRequest
            {
                PageNumber = state.Page + 1,
                PageSize = state.PageSize,
                SortBy = string.IsNullOrWhiteSpace(state.SortLabel) ? "executedAt" : state.SortLabel,
                SortDescending = state.SortDirection != SortDirection.Ascending
            }, cancellationToken);

            return new TableData<ApiCallLogDto>
            {
                Items = response.Items,
                TotalItems = response.Paging.TotalItems
            };
        }
        catch (HttpRequestException ex) when (ex.StatusCode is System.Net.HttpStatusCode.Unauthorized
            or System.Net.HttpStatusCode.Forbidden)
        {
            Session.SignOut();
            NavigationManager.NavigateTo("/");
            return new TableData<ApiCallLogDto> { Items = [], TotalItems = 0 };
        }
        catch (Exception)
        {
            return new TableData<ApiCallLogDto> { Items = [], TotalItems = 0 };
        }
    }

    private async Task LoadExistingScheduleAsync(Guid apiCallId)
    {
        var schedules = await ApiClient.GetSchedulesAsync();
        var matchingSchedules = schedules
            .Where(x => x.ApiCallId == apiCallId)
            .OrderBy(x => x.ScheduleId)
            .ToList();

        if (matchingSchedules.Count == 0)
        {
            return;
        }

        _schedules.Clear();
        foreach (var schedule in matchingSchedules)
        {
            _schedules.Add(new ScheduleEditorModel
            {
                ScheduleId = schedule.ScheduleId,
                CronExpression = schedule.CronExpression,
                IsEnabled = schedule.IsEnabled
            });
        }

        UpdateAllSchedulePreviews();
    }

    private void OnLogRowClick(TableRowClickEventArgs<ApiCallLogDto> args)
    {
        if (args.Item is null)
        {
            return;
